abbr j "jj"
abbr jc "jj commit"
abbr jd "jj describe"
abbr je "jj edit"
abbr jgf "jj git fetch"
abbr jgp "jj git push"
abbr jn "jj new"
abbr js "jj show"
abbr jst "jj status"
abbr jw "watch -ctw jj --color=always --ignore-working-copy --no-pager"
abbr jwx "watch -ctw jj log -r \"'full()'\" --color=always --ignore-working-copy --no-pager"
abbr jx "jj log -r 'full()'"
