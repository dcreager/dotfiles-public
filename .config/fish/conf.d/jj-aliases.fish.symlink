abbr j "jj"
abbr ja "jj abandon"
abbr jc "jj commit"
abbr jd "jj describe"
abbr je "jj edit"
abbr jgf "jj git fetch"
abbr jgp "jj git push"
abbr jl "jj log"
abbr jn "jj new"
abbr jnw "jj new --ignore-working-copy"
abbr jp "jj split"
abbr jq "jj squash"
abbr jr "jj rebase"
abbr js "jj show"
abbr jw "watch -ctw jj log --color=always --ignore-working-copy --no-pager"
abbr jwx "watch -ctw jj log -r \"'full()'\" --color=always --ignore-working-copy --no-pager"
abbr jx "jj log -r 'full()'"
