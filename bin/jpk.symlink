#!/bin/bash

if ! jj root --ignore-working-copy >/dev/null 2>&1; then
    echo "You must run this from a jj workspace" >&2
    exit 1
fi

export GIT_DIR=$(jj git root --ignore-working-copy)
TRUNK=$(jj show --color=never --no-patch --ignore-working-copy -r 'trunk()' --template 'commit_id')
HEAD=$(jj show --color=never --no-patch --ignore-working-copy -r @ --template 'commit_id')

exec prek run --from-ref "$TRUNK" --to-ref "$HEAD"
